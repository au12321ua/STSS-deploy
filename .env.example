# ═══════════════════════════════════════════════════════════════════
# STSS Deploy — Environment Variables
#
# Copy to .env and customize:
#   cp .env.example .env
#
# Then start everything:
#   docker compose up -d                    # start all services
#   docker compose --profile seed up seed schedule_seed  # one-time data seeding
#   curl http://localhost:8000/api/v1/health
#
# ═══════════════════════════════════════════════════════════════════

# ── Gateway Configuration ─────────────────────────────────────────
GATEWAY_PORT=8000
GATEWAY_CLIENT_ID=gateway
GATEWAY_CLIENT_SECRET=change-me-gateway-secret
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_LOGIN=10r/m

# ── Upstream Service Addresses (Docker internal hostnames) ────────
# These are passed to the gateway container so it knows where to
# route each /api/v1/<module>/* path.
AUTH_SERVICE_URL=auth_service:8001
INFO_SERVICE_URL=info_service:8002
SCHEDULE_SERVICE_URL=schedule_service:8003
COURSE_SELECTION_SERVICE_URL=course-selection-api:8004
FORUM_SERVICE_URL=forum_service:8005
ONLINE_TEST_SERVICE_URL=online_test_service:8006
GRADE_SERVICE_URL=grade_service:8007

# ── Shared Secrets ────────────────────────────────────────────────
# TOKEN_SECRET_KEY — JWT signing key, MUST be identical across
#   auth_service and info_service containers.
#   Generate: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# INFO_SERVICE_CLIENT_SECRET — credential that Info Service uses to
#   call Auth Service /auth/sys/login.  Must match auth_service's
#   SERVICE_CLIENT_INFO_SERVICE_SECRET.
INFO_SERVICE_CLIENT_SECRET=change-me-service-secret

# SCHEDULE_SERVICE_CLIENT_SECRET — credential that Schedule Service uses to
#   call Auth Service /auth/sys/login through the Gateway.
SCHEDULE_SERVICE_CLIENT_ID=schedule_service
SCHEDULE_SERVICE_CLIENT_SECRET=change-me-schedule-service-secret

# ── Schedule Service ─────────────────────────────────────────────
SCHEDULE_MYSQL_PASSWORD=rootpassword
SCHEDULE_MYSQL_DB=course_arrange

# Local debug ports used only by docker-compose.override.yml.example.
# Main deployment keeps Schedule API/MySQL/Redis internal to stss-net.
# SCHEDULE_API_PORT=8003
# SCHEDULE_MYSQL_PORT=3309
# SCHEDULE_REDIS_PORT=6382

# ── Runtime ───────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=DEBUG

# ── Docker Image Overrides (optional) ─────────────────────────────
# By default images are pulled from ghcr.io/au12321ua/*.
# Uncomment to use custom images:
# GATEWAY_IMAGE=ghcr.io/au12321ua/stss-gateway:latest
# AUTH_SERVICE_IMAGE=my-auth:latest
# INFO_SERVICE_IMAGE=my-info:latest
# SEED_IMAGE=my-seed:latest
# SCHEDULE_IMAGE=ghcr.io/uppi7/zjuse-schedule:latest

# ── Front-end path (dev profile) ──────────────────────────────────
# FRONTEND_PATH=./frontend
