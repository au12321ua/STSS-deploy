# docker-compose.override.yml — Local development overrides
#
# Copy this to docker-compose.override.yml to build backend images
# from local source repositories instead of pulling from GHCR.
#
# Prerequisites:
#   The backend source repositories must exist in sibling directories.
#   By default the paths assume this layout:
#     ../group1-base/auth_service/Dockerfile
#     ../group1-base/info_service/Dockerfile
#     ../group1-base/scripts/Dockerfile (seed)
#     ../STSS-gateway/Dockerfile
#     ../zjuse-schedule/Dockerfile
#     ../Smart-Class-Selection-backend/deploy/Dockerfile
#     ../STSS-forum-backend/Dockerfile
#     ../STSS-Online-Testing/java/Dockerfile
#     ../STSS-Online-Testing/go/logger/Dockerfile
#     ../STSS-Online-Testing/go/proctor/Dockerfile.multi
#     ../SE-Group6/Dockerfile
#     ../SSTS-frontend/Dockerfile
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose --profile local-build build gateway auth_service info_service seed schedule_service schedule_worker schedule_seed course-selection-api course-selection-worker forum_service online_test_logger online_test_service online_test_proctor_controller online_test_proctor_image grade_service frontend
#   docker compose up -d
#   docker compose --profile seed up seed schedule_seed
#
# This override also publishes Schedule API/MySQL/Redis to the
# host for local debugging. Main deployment keeps them internal to
# the Docker network; only the gateway is exposed by default.
#
# To switch back to GHCR images, remove the override file:
#   rm docker-compose.override.yml
#   docker compose up -d
#
services:
  gateway:
    build:
      context: ../STSS-gateway
    image: stss-gateway:local

  auth_service:
    build:
      context: ../group1-base
      dockerfile: auth_service/Dockerfile

  info_service:
    build:
      context: ../group1-base
      dockerfile: info_service/Dockerfile

  seed:
    build:
      context: ../group1-base
      dockerfile: scripts/Dockerfile

  schedule_seed:
    build:
      context: ../zjuse-schedule
    image: stss-schedule:local

  schedule_service:
    build:
      context: ../zjuse-schedule
    image: stss-schedule:local
    ports:
      - "${SCHEDULE_API_PORT:-8003}:8003"

  schedule_worker:
    build:
      context: ../zjuse-schedule
    image: stss-schedule:local

  schedule_mysql:
    ports:
      - "${SCHEDULE_MYSQL_PORT:-3309}:3306"

  schedule_redis:
    ports:
      - "${SCHEDULE_REDIS_PORT:-6382}:6379"

  course-selection-api:
    build:
      context: ../Smart-Class-Selection-backend
      dockerfile: deploy/Dockerfile
    image: stss-course-selection:local

  course-selection-worker:
    build:
      context: ../Smart-Class-Selection-backend
      dockerfile: deploy/Dockerfile
    image: stss-course-selection:local

  forum_service:
    build:
      context: ../STSS-forum-backend
    image: stss-forum:local
    container_name: stss-forum
    profiles: !reset []
    environment:
      ENV: "${ENV:-development}"
      FORUM_PORT: "8005"
      DATABASE_URL: "sqlite:///./data/forum.db"
      UPLOAD_DIR: "/app/uploads"
      PUBLIC_UPLOAD_PREFIX: "/api/v1/forum/uploads"
      LEGACY_UPLOAD_PREFIX: "/uploads"
      ENABLE_CORS: "false"
      INFO_SERVICE_URL: "http://info_service:8002"
      COURSE_SELECTION_SERVICE_URL: "http://course-selection-api:8004"
      SCORE_SERVICE_URL: "http://grade_service:8007"
      INTERNAL_TOKEN: "${INTERNAL_TOKEN:-dev-internal-token}"
    expose:
      - "8005"
    volumes:
      - forum_data:/app/data
      - forum_uploads:/app/uploads
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8005/api/v1/health')"]
      interval: 15s
      timeout: 3s
      retries: 5
      start_period: 10s

  online_test_logger:
    build:
      context: ../STSS-Online-Testing/go/logger
      dockerfile: Dockerfile
    image: stss-online-testing-logger:local

  online_test_service:
    build:
      context: ../STSS-Online-Testing
      dockerfile: java/Dockerfile
    image: stss-online-testing-service:local
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8006/api/v1/health"]
      interval: 15s
      timeout: 3s
      retries: 5
      start_period: 20s

  online_test_proctor_image:
    build:
      context: ../STSS-Online-Testing/go
      dockerfile: proctor/Dockerfile.multi
      target: proctor
    image: stss-online-testing-proctor:local
    profiles: ["local-build"]
    entrypoint: ["/bin/sh", "-c", "exit 0"]

  online_test_proctor_controller:
    build:
      context: ../STSS-Online-Testing/go
      dockerfile: proctor/Dockerfile.multi
      target: controller
    image: stss-online-testing-controller:local
    environment:
      PROCTOR_IMAGE: stss-online-testing-proctor:local

  grade_service:
    build:
      context: ../SE-Group6
      dockerfile: Dockerfile
    image: stss-grade:local

  frontend:
    build:
      context: ../SSTS-frontend
    image: stss-frontend:local

volumes:
  forum_data:
  forum_uploads:
