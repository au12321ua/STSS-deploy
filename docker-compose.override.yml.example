# docker-compose.override.yml — Local development overrides
#
# Copy this to docker-compose.override.yml to build backend images
# from local source repositories instead of pulling from GHCR.
#
# Prerequisites:
#   The backend source repositories must exist in sibling directories.
#   By default the paths assume this layout:
#     ../group1-base/auth_service/Dockerfile
#     ../group1-base/info_service/Dockerfile
#     ../group1-base/scripts/Dockerfile (seed)
#     ../schedule/Dockerfile
#     ../Smart-Class-Selection-backend/deploy/Dockerfile
#     ../STSS-forum-backend/Dockerfile
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   docker compose build auth_service info_service seed schedule_service schedule_worker schedule_seed course-selection-api course-selection-worker forum_service
#   docker compose up -d
#   docker compose --profile seed up seed schedule_seed
#
# This override also publishes Schedule API/MySQL/Redis to the
# host for local debugging. Main deployment keeps them internal to
# the Docker network; only the gateway is exposed by default.
#
# To switch back to GHCR images, remove the override file:
#   rm docker-compose.override.yml
#   docker compose up -d
#
# Note: The gateway image is always pulled from GHCR unless you
# override GATEWAY_IMAGE in .env.  To build the gateway locally,
# clone https://github.com/au12321ua/STSS-gateway and run
# docker build there.

services:
  auth_service:
    build:
      context: ../group1-base
      dockerfile: auth_service/Dockerfile

  info_service:
    build:
      context: ../group1-base
      dockerfile: info_service/Dockerfile

  seed:
    build:
      context: ../group1-base
      dockerfile: scripts/Dockerfile

  schedule_seed:
    build:
      context: ../schedule

  schedule_service:
    build:
      context: ../schedule
    ports:
      - "${SCHEDULE_API_PORT:-8003}:8003"

  schedule_worker:
    build:
      context: ../schedule

  schedule_mysql:
    ports:
      - "${SCHEDULE_MYSQL_PORT:-3309}:3306"

  schedule_redis:
    ports:
      - "${SCHEDULE_REDIS_PORT:-6382}:6379"

  course-selection-api:
    build:
      context: ../Smart-Class-Selection-backend
      dockerfile: deploy/Dockerfile

  course-selection-worker:
    build:
      context: ../Smart-Class-Selection-backend
      dockerfile: deploy/Dockerfile

  forum_service:
    build:
      context: ../STSS-forum-backend
      dockerfile: Dockerfile
    ports:
      - "${FORUM_API_PORT:-8005}:8005"
